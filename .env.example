TELEGRAM_BOT_TOKEN=
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=google/gemma-3-4b
LM_STUDIO_EMBEDDING_MODEL=nomic-embed-text-v1.5
PDF_DIR=./Papers
# Optional: fixed single paper path (absolute or relative to PDF_DIR)
SINGLE_PAPER_PATH=
# Local macOS run: http://localhost:8070
# If bot runs in Docker and GROBID runs on host: http://host.docker.internal:8070
GROBID_URL=http://localhost:8070
GROBID_TIMEOUT_SEC=120
SESSION_STATE_DIR=sessions/state
TELEBOT_API_PORT=8000
# Optional: if set, all API requests must include matching X-API-Key header
TELEBOT_API_KEY=
